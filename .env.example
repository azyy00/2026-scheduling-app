# GCC Class Scheduling System — required environment variables
# Copy to .env.local for local dev and set the same values in Vercel (Production/Preview).

# TiDB Serverless (MySQL-compatible) connection
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=

# JWT signing secret — REQUIRED. The app fails closed (refuses to issue/verify tokens) if unset.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Admin password reset email
# ADMIN_EMAIL seeds the default admin account's recovery email if it has none yet.
ADMIN_EMAIL=

# Option A: Resend email delivery
# MAIL_FROM must be a verified sender in Resend, e.g. "Goa Community College <no-reply@yourdomain.com>"
RESEND_API_KEY=
MAIL_FROM=

# Option B: SMTP email delivery
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true,
# SMTP_USER=youraddress@gmail.com, SMTP_PASS=your Google app password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
